{
  "name": "@llm-optimize/openai",
  "version": "0.1.2",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "openai",
    "gpt-4",
    "gpt-4o",
    "gpt-3.5-turbo",
    "openai-api",
    "openai-typescript",
    "chat-completions",
    "azure-openai",
    "groq",
    "together-ai",
    "openai-compatible",
    "llm-provider",
    "llm-adapter",
    "llm-middleware",
    "ai-typescript",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@llm-optimize/core": "^0.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
