{
  "name": "@llm-optimize/core",
  "version": "0.1.3",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "llm",
    "llm-optimization",
    "llm-middleware",
    "llm-cost-savings",
    "token-reduction",
    "prompt-compression",
    "llm-caching",
    "llm-analytics",
    "llm-retry",
    "llm-security",
    "sensitive-data-redaction",
    "model-routing",
    "token-budget",
    "context-trimming",
    "openai-middleware",
    "anthropic-middleware",
    "aws-bedrock",
    "gemini-adapter",
    "ollama",
    "llm-proxy",
    "ai-cost-optimization",
    "typescript",
    "json-repair"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
