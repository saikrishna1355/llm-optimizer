{
  "name": "@llm-optimize/cli",
  "version": "0.1.3",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "llm-cli",
    "prompt-linting",
    "prompt-analysis",
    "token-count-cli",
    "prompt-quality",
    "prompt-benchmark",
    "llm-cost-analysis",
    "prompt-optimizer-cli",
    "ai-prompt-tools",
    "prompt-file-linter",
    "token-estimation",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "llm-opt": "./dist/index.js"
  },
  "scripts": {
