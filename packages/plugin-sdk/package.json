{
  "name": "@llm-optimize/plugin-sdk",
  "version": "0.1.2",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "llm-plugin",
    "llm-plugin-sdk",
    "llm-middleware",
    "llm-extensibility",
    "custom-llm-plugin",
    "llm-request-interceptor",
    "llm-analytics-plugin",
    "llm-observability",
    "model-router-plugin",
    "ai-plugin-system",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@llm-optimize/core": "^0.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
