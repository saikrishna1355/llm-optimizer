{
  "name": "@llm-optimize/anthropic",
  "version": "0.1.3",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "anthropic",
    "claude",
    "claude-3",
    "claude-3-haiku",
    "claude-3-sonnet",
    "claude-3-opus",
    "anthropic-api",
    "anthropic-typescript",
    "aws-bedrock",
    "bedrock-claude",
    "llm-provider",
    "llm-adapter",
    "llm-middleware",
    "openai-alternative",
    "ai-typescript",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@llm-optimize/core": "^0.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
